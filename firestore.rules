rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isClient() {
      return isAuthenticated() && getUserRole() == 'client';
    }

    function isFreelancer() {
      return isAuthenticated() && getUserRole() == 'freelancer';
    }

    function isProjectMember(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId));
      return isAuthenticated() && (
        project.data.clientId == request.auth.uid ||
        project.data.assignedFreelancerId == request.auth.uid ||
        isAdmin()
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isUser(userId) || 
        isAdmin() || 
        (isFreelancer() && resource.data.role == 'client') ||
        (isClient() && resource.data.role == 'freelancer')
      );
      allow create: if isAdmin() || (isAuthenticated() && isUser(userId));
      allow update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedFreelancerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isClient() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedFreelancerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isClient() && resource.data.clientId == request.auth.uid);
    }

    // Tasks collection (marketplace tasks)
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedFreelancerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.assignedFreelancerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Task Applications collection
    match /taskApplications/{applicationId} {
      allow read: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Drawings collection
    match /drawings/{drawingId} {
      allow read: if isAuthenticated() && (
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uploadedBy == request.auth.uid);
    }

    // Time Entries collection
    match /timeEntries/{entryId} {
      allow read: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Proofs collection
    match /proofs/{proofId} {
      allow read: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Messages collection
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Conversations collection
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      allow delete: if isAdmin();
    }

    // Files collection
    match /files/{fileId} {
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uploadedBy == request.auth.uid);
    }

    // Hour packages collection
    match /hourPackages/{packageId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isClient() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Project requests collection
    match /projectRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isClient() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Compliance checks collection
    match /complianceChecks/{checkId} {
      allow read: if isAuthenticated() && (
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Audit logs collection (renamed from auditLogs to match code)
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Security events collection
    match /security_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }

    // Hour purchases collection
    match /hourPurchases/{purchaseId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isClient() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Withdrawal requests collection
    match /withdrawalRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Drawing submissions collection
    match /drawingSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (
        isProjectMember(resource.data.projectId) ||
        isAdmin()
      );
      allow create: if isFreelancer() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.freelancerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Settings collection - admin only
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny all other paths
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
