# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these values from your Firebase Console: Project Settings > General > Your apps > SDK setup and configuration

# Firebase API Key
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain (e.g., your-project.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase Storage Bucket (e.g., your-project.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Optional: Enable Firebase emulators for local development
# VITE_USE_FIREBASE_EMULATOR=true

# API URL for server-side R2 operations
# Configure this to point to your Cloudflare Worker or other server-side API
# This avoids exposing R2 credentials in the browser bundle
VITE_API_URL=https://your-worker.subdomain.workers.dev
