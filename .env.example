# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these values from your Firebase Console: Project Settings > General > Your apps > SDK setup and configuration

# Firebase API Key
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain (e.g., your-project.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase Storage Bucket (e.g., your-project.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Optional: Enable Firebase emulators for local development
# VITE_USE_FIREBASE_EMULATOR=true

# Cloudflare R2 Storage Configuration
# Used for file uploads (drawings, proofs, profile images)
# Get these from your Cloudflare R2 dashboard: Manage R2 API Tokens
VITE_R2_ACCESS_KEY_ID=your_r2_access_key_id
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Note: R2 endpoint is configured in the code as:
# https://fce57ea059c228c5cec72d0b7055c268.r2.cloudflarestorage.com/architex
